# Backend .dockerignore — keeps the build context small.
# Anything in .git / data / cache is not needed in the image.
.git
.gitignore
.env
.env.*
!.env.example
__pycache__
**/__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache
.coverage
htmlcov
tests/
docs/
agent.log
*.log
.DS_Store
node_modules
.vscode
.idea
